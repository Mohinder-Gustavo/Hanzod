WindowManager:
    MainScreen:
        name: 'main'
    MenuScreen:
        name: 'menu'


# =========================
# INPUT CLARO (CONTRASTE)
# =========================
<RoundedInput@TextInput>:
    multiline: False
    padding: [14, 12]
    background_color: [0, 0, 0, 0]

    # Texto escuro (porque o fundo é claro)
    foreground_color: [0.1, 0.1, 0.1, 1]

    # Hint suave
    hint_text_color: [0.25, 0.25, 0.25, 1]

    font_size: '16sp'
    cursor_color: [0.85, 0.7, 0.2, 1]

    canvas.before:
        # Fundo claro
        Color:
            rgba: [0.95, 0.95, 0.97, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10,]

        # Borda elegante
        Color:
            rgba: [0.8, 0.8, 0.85, 1] if not self.focus else [0.85, 0.7, 0.2, 1]
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, 10)
            width: 1.2


# =========================
# BOTÃO DARK-GOLD
# =========================
<GoldButton@Button>:
    background_color: [0,0,0,0]
    color: [0.95, 0.95, 0.95, 1]
    bold: True

    canvas.before:
        Color:
            rgba: [0.18, 0.18, 0.2, 1] if self.state == 'normal' else [0.12, 0.12, 0.14, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [12,]

        Color:
            rgba: [0.3, 0.3, 0.35, 1]
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, 12)
            width: 1


# =========================
# BOTÃO PRINCIPAL (OURO)
# =========================
<PrimaryGoldButton@Button>:
    background_color: [0,0,0,0]
    color: [0, 0, 0, 1]
    bold: True

    canvas.before:
        Color:
            rgba: [0.85, 0.7, 0.2, 1] if self.state == 'normal' else [0.7, 0.55, 0.15, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [14,]


# =========================
# MAIN SCREEN
# =========================
<MainScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [25, 40, 25, 40]
        spacing: 15

        canvas.before:
            Color:
                rgba: [0.04, 0.04, 0.05, 1]
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Hanzod"
            font_name: "Oriental Chicken.ttf"
            font_size: '28sp'
            bold: True
            color: [0.85, 0.7, 0.2, 1]
            size_hint_y: None
            height: '80dp'

        RoundedInput:
            id: name_input
            hint_text: "Nome Completo"
            size_hint_y: None
            height: '48dp'

        BoxLayout:
            size_hint_y: None
            height: '48dp'
            spacing: 10

            RoundedInput:
                id: day
                hint_text: "Dia"
                input_filter: 'int'

            RoundedInput:
                id: month
                hint_text: "Mês"
                input_filter: 'int'

            RoundedInput:
                id: year
                hint_text: "Ano"
                input_filter: 'int'

        PrimaryGoldButton:
            text: "CALCULAR SIGNO LUNAR"
            size_hint_y: None
            height: '56dp'
            on_release: root.calculate()

        # RESULTADO
        BoxLayout:
            padding: 12

            canvas.before:
                Color:
                    rgba: [0.1, 0.1, 0.12, 1]
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [12,]

            Label:
                text: root.result_text
                font_name: 'NotoSansCJK.otf'
                markup: True
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                color: [0.9, 0.9, 0.9, 1]
                font_size: '17sp'

        BoxLayout:
            size_hint_y: None
            height: '50dp'
            spacing: 12

            GoldButton:
                text: "GUARDAR"
                on_release: root.save_profile()

            GoldButton:
                text: "MEUS PERFIS"
                on_release: app.root.current = 'menu'


# =========================
# MENU SCREEN
# =========================
<MenuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15

        canvas.before:
            Color:
                rgba: [0.04, 0.04, 0.05, 1]
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "PERFIS SALVOS"
            size_hint_y: None
            height: '60dp'
            font_size: '22sp'
            bold: True
            color: [0.85, 0.7, 0.2, 1]

        ScrollView:
            do_scroll_x: False

            GridLayout:
                id: container
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 10

        GoldButton:
            text: "VOLTAR"
            size_hint_y: None
            height: '50dp'
            on_release: app.root.current = 'main'
